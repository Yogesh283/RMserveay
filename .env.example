APP_NAME="RM Survey"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# SPA / Sanctum — Live checklist (fixes 401 on /api/user after login):
# APP_URL=https://your-domain.com   (must be HTTPS + exact public host)
# SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com   (optional if APP_URL is correct; config adds www↔apex automatically when unset)
# SESSION_DOMAIN=.your-domain.com   (optional; leading dot shares cookie on www + apex)
# SESSION_SECURE_COOKIE=true        (recommended when served only over HTTPS)
# CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# SPA / Sanctum (comma-separated hosts, no scheme)
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,tast.updowanfx.com

# Set true only for local/dev — skips email OTP on login + register (never in production)
OTP_BYPASS=false

# CORS: explicit origins when axios uses credentials (required if SPA and API differ by host/port).
# Defaults to APP_URL if unset. Example: CORS_ALLOWED_ORIGINS=https://tast.updowanfx.com
# CORS_ALLOWED_ORIGINS=
# CORS_SUPPORTS_CREDENTIALS=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Blade compile + PHP temp (production: avoid tempnam() warnings if system /tmp is restricted)
# VIEW_COMPILED_PATH is optional; default is storage/framework/views
# TMPDIR is set early by bootstrap/runtime.php to storage/tmp — keep that directory writable.

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
AUTH_SESSION_MAX_MINUTES=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Live HTTPS: leave unset or true (AppServiceProvider forces true when APP_URL is https)
# SESSION_SECURE_COOKIE=true

# OTP lives in Cache between "Send OTP" and "Log in" — do NOT use CACHE_STORE=array on production.
# CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

# RM Survey self survey income (optional overrides; defaults match member docs)
# SELF_SURVEY_PANELIST_USD=0.01
# SELF_SURVEY_ACTIVATION_FEE_USD=1.00
# SELF_SURVEY_MIN_PANEL_FEE_USD=10.00
# SELF_SURVEY_ACTIVE_USD=1.00
# SELF_SURVEY_SUB_PANEL_FEE_USD=10.00
# SELF_SURVEY_SUB_PER_SURVEY_USD=1.00
# SELF_SURVEY_SUPER_SUB_FEE_USD=100.00
# SELF_SURVEY_SUPER_SUB_PER_SURVEY_USD=10.00
# SELF_SURVEY_MAX_SUB_PANELS=9
# SELF_SURVEY_MAX_SUPER_SUB_PANELS=9

# Direct income — 10% = 0.10
# DIRECT_INCOME_RATE=0.10

# Panel matching — 10% of ($10+$10) pair volume = $2/pair by default
# PANEL_MATCHING_RATE=0.10
# PANEL_MATCHING_PAIR_VOLUME_USD=10.00
# PANEL_MATCHING_MAX_PAIRS_PER_DAY=20

# Sub-panel tabular matching (milestones 2…256 panels, income = milestone USD, daily cap)
# SUB_PANEL_MATCHING_DAILY_CAP_USD=256.00
# SUB_PANEL_MATCHING_RATE=0.10

# Super sub-panel tabular matching (income = milestone × multiplier; default 10× → $2560 max tier)
# SUPER_SUB_PANEL_MATCHING_DAILY_CAP_USD=2560.00
# SUPER_SUB_PANEL_MATCHING_INCOME_MULTIPLIER=10
# SUPER_SUB_PANEL_MATCHING_RATE=0.10

# Survey level income — 1% per sponsor generation per survey credit (max levels)
# LEVEL_INCOME_MAX_LEVELS=10
# LEVEL_INCOME_RATE_PER_LEVEL=0.01

# Wallet (USDT BEP-20 display + treasury for deposits)
# WALLET_NETWORK_LABEL="BEP-20 (Binance Smart Chain)"
# WALLET_ASSET_SYMBOL=USDT
# WALLET_TREASURY_BEP20=0xYourTreasuryAddressHere
# WALLET_MIN_DEPOSIT_USD=1.00
# WALLET_MIN_WITHDRAW_USD=10.00
# WALLET_MIN_P2P_USD=0.01
# Direct withdrawal fee on gross amount from main wallet (15% = 0.15)
# WALLET_DIRECT_WITHDRAWAL_FEE_RATE=0.15
# Bonus rate when moving main → internal P2P wallet (10% = 0.10)
# WALLET_MAIN_TO_P2P_BONUS_RATE=0.10

# NOWPayments (optional crypto deposit gateway — set IPN URL in dashboard to: {APP_URL}/api/payments/nowpayments/ipn)
# Dashboard: Account → Payment settings → add your Outcome / payout wallet (USDT BEP20 = same network as pay currency).
# Mass payout API (admin → users): whitelist server IP + destination wallets in NP Settings → Whitelist.
# NOWPAYMENTS_ENABLED=false
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_PAY_CURRENCY=usdtbsc
# Comma list of pay_currency values shown in member deposit UI (must be enabled on your NP account)
# NOWPAYMENTS_ALLOWED_PAY_CURRENCIES=usdtbsc,usdttrc20,usdterc20
# NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
# Comma-separated statuses that trigger one wallet credit (default faster than waiting only for finished)
# NOWPAYMENTS_CREDIT_STATUSES=finished,confirmed
# Optional: force settlement to this address on every create_payment (else falls back to WALLET_TREASURY_BEP20)
# NOWPAYMENTS_PAYOUT_ADDRESS=0xYourAdminUsdtBep20Address
# NOWPAYMENTS_PAYOUT_CURRENCY=usdtbsc
#
# Member withdrawals → NOWPayments Mass Payout (admin: Wallet → Withdrawals)
# Use the same API key; account email/password for POST /auth (master account 2FA).
# Enable Custody, whitelist server IP + member BEP20 addresses in NP dashboard.
# NOWPAYMENTS_PAYOUTS_ENABLED=false
# NOWPAYMENTS_PAYOUT_EMAIL=your@nowpayments-account.email
# NOWPAYMENTS_PAYOUT_PASSWORD=your-account-password

# URL-based cron auth token. Set this on production and call:
#   GET {APP_URL}/cron/binary-daily-closing?token=YOUR_TOKEN
# Use a long random string (32+ chars). Leave empty to disable the URL endpoint.
# CRON_TOKEN=

# Membership plans (sequential) — edit config/membership_plans.php for names/prices
